{
    "name": "open-classbook/open-classbook",
    "description": "Schlanke Schulplattform fuer kleinere Schulen",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "phpoffice/phpspreadsheet": "^5.5",
        "tecnickcom/tcpdf": "^6.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "OpenClassbook\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenClassbook\\Tests\\": "tests/"
        }
    }
}
